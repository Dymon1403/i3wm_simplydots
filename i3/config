client.unfocused         $cl_inactive $cl_inactive $cl_foreground $cl_inactive $cl_inactive
client.urgent            $cl_urgent $cl_urgent $cl_foreground $cl_urgent $cl_urgent
client.focused           $cl_active $cl_active $cl_foreground $cl_active $cl_active
client.focused_inactive  $cl_inactive $cl_inactive $cl_foreground $cl_inactive $cl_inactive
client.unfocused         $cl_inactive $cl_inactive $cl_foreground $cl_inactive $cl_inactive
